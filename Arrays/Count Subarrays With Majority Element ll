class Solution {
public:
    long long countMajoritySubarrays(vector<int>& nums, int target) {
        int n = nums.size();

        unordered_map<int,int> mp;
        mp[0] = 1;

        long long result = 0;

        long long cumSum = 0;

        int leftValidPoints = 0;

        for(int i=0; i<n; i++){
            if(nums[i]==target){
                leftValidPoints += mp[cumSum];
                cumSum++;
            }
            else{
                cumSum--;
                leftValidPoints -= mp[cumSum];
            }
            mp[cumSum]+=1;
            result += (long long) leftValidPoints;
        }

        return result;
    }
};

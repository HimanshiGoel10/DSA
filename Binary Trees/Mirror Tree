class Solution {
  public:
    void mirror(Node* root) {
        
        if(!root) return;
        mirror(root->left);
        mirror(root->right);
        
        Node* left = root->left;
        Node* right = root->right;
        
        root->left = right;
        root->right = left;
    }
};

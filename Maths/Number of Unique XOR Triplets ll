class Solution {
public:
    int uniqueXorTriplets(vector<int>& nums) {

        int n = nums.size();
        unordered_set <int> pairXors;

        for(int i=0; i<n; i++){
            for(int j=i; j<n; j++){
                pairXors.insert(nums[i]^nums[j]);
            }
        }

        unordered_set <int> result;

        for(int i=0; i<n; i++){
            for(auto &x: pairXors){
                result.insert(nums[i]^(x));
            }
        }

        return result.size();
    }
};
